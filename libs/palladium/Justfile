#!/usr/bin/env just --justfile

# List available recipes
default:
    @just --list

# ── TypeScript ────────────────────────────────────────────────────────────────

# Lint all TypeScript with Biome (runs once from repo root)
lint-ts:
    pnpm exec biome check .

# Format all TypeScript with Biome (runs once from repo root)
fmt-ts:
    pnpm exec biome format --write .

# Run all TypeScript tests via Vitest workspace
test-ts:
    pnpm exec vitest run

# Type-check all TypeScript packages
typecheck-ts:
    pnpm -r run typecheck

# Build all TypeScript packages
build-ts:
    pnpm -r run build

# ── Rust ──────────────────────────────────────────────────────────────────────

# Lint Rust workspace with Clippy
lint-rust:
    cargo clippy --workspace --all-features --all-targets -- -D warnings

# Format Rust workspace
fmt-rust:
    cargo fmt --all

# Run all Rust tests
test-rust:
    cargo test --workspace --all-features

# Check Rust workspace (no codegen)
check-rust:
    cargo check --workspace --all-features

# Build Rust workspace
build-rust:
    cargo build --workspace --all-features

# Build Rust workspace (release)
build-rust-release:
    cargo build --workspace --all-features --release

# ── Coverage & mutation testing ───────────────────────────────────────────────

# Measure code coverage and open an HTML report (requires: cargo install cargo-llvm-cov)
# Note: --all-features is intentionally omitted; palladium-postgres/integration-tests
# requires DATABASE_URL and is covered separately in CI.
coverage:
    cargo llvm-cov --workspace --html
    @echo "Coverage report: target/llvm-cov/html/index.html"

# Print a line-coverage summary to stdout without generating HTML
coverage-summary:
    cargo llvm-cov --workspace --summary-only

# Run mutation tests across the Rust workspace (requires: cargo install cargo-mutants)
# Results are written to target/mutants/; see target/mutants/missed.txt for survivors.
mutants:
    cargo mutants --workspace

# TypeScript: run tests with coverage report for all packages
coverage-ts:
    pnpm exec vitest run --coverage
    @echo "Coverage reports written to coverage/ in each package directory"

# TypeScript: run Stryker mutation tests against @palladium/core
# Results are written to reports/mutation/; open reports/mutation/index.html for the HTML report.
mutants-ts:
    pnpm exec stryker run

# ── Security / Auditing ───────────────────────────────────────────────────────

# Run cargo-deny license + advisory checks
deny:
    cargo deny check

# Run cargo-audit vulnerability scan
audit:
    cargo audit

# Check for unused dependencies
machete:
    cargo machete

# ── E2E & contract tests ──────────────────────────────────────────────────────

# End-to-end tests: TypeScript client against a live Rust server.
# Builds the debug binary, installs packages, then runs Vitest.
test-e2e: build-rust
    pnpm -C packages/core run build
    pnpm -C packages/e2e exec vitest run

# ── Vue TODO example app ──────────────────────────────────────────────────────

# Start the Vue TODO example app in dev mode
dev-example-vue:
    pnpm -C packages/example-vue exec vite

# Install Playwright browsers (run once after first pnpm install)
install-playwright:
    pnpm -C packages/example-vue exec playwright install chromium

# Run Playwright E2E tests for the Vue TODO example app
test-example-vue:
    pnpm -C packages/example-vue exec playwright test

# ── CATS ─────────────────────────────────────────────────────────────────────

# CATS contract + fuzz tests against the OpenAPI spec.
# Runs CATS via testcontainers (Docker) against an in-process Axum server.
# Requires Docker to be running.
cats:
    cargo test -p palladium-axum --features cats-tests --test cats -- --nocapture

# ── Combined ──────────────────────────────────────────────────────────────────

# Lint everything
lint: lint-ts lint-rust

# Format everything
fmt: fmt-ts fmt-rust

# Test everything
test: test-ts test-rust

# Build everything
build: build-ts build-rust

# Full CI check (matches CI pipeline)
ci: lint test deny audit

# Pre-release check (includes machete)
preflight: ci machete typecheck-ts
