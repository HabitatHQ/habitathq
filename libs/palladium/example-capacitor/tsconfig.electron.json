{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.base.json",
  "include": ["electron/src"],
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "outDir": "electron/dist",
    "rootDir": "electron/src",
    "types": ["node"]
  }
}
