{
  "name": "habitat-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:habitat": "pnpm --filter habitat dev",
    "dev:hearth": "pnpm --filter hearth dev",
    "dev:halcyon": "pnpm --filter halcyon dev",
    "dev:hephaestus": "pnpm --filter hephaestus dev",
    "dev:landing": "npx --yes live-server apps/landing --port=4200 --no-browser",
    "build": "pnpm -r build:pwa",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "check": "pnpm -r check",
    "check:fix": "pnpm -r check:fix",
    "typecheck": "pnpm -r typecheck",
    "test:unit": "pnpm -r test:unit",
    "test": "pnpm -r test",
    "ci": "pnpm -r ci && pnpm lint:deps && pnpm dedupe:check",
    "verify": "pnpm ci",
    "clean": "pnpm -r clean",
    "lint:semgrep": "semgrep scan --config semgrep.yml --metrics=off --error --severity=ERROR --quiet",
    "lint:semgrep:all": "semgrep scan --config semgrep.yml --metrics=off --quiet apps libs",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs --output-type err apps libs",
    "lint:deps:graph": "depcruise --config .dependency-cruiser.cjs --output-type dot apps libs | dot -T svg -o dependency-graph.svg",
    "dedupe:check": "pnpm dedupe --check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@typescript/native-preview": "7.0.0-dev.20260501.1",
    "axe-core": "^4.11.1",
    "dependency-cruiser": "^17.4.2",
    "lefthook": "^2.1.6",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi"
    ]
  }
}
