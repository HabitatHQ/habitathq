{
  "root": false,
  "extends": ["../../biome.json"],

  "files": {
    "includes": ["app/**/*.ts", "app/**/*.vue", "nuxt.config.ts"]
  },

  "linter": {
    "rules": {
      "complexity": {
        "useLiteralKeys": "off"
      }
    }
  },

  "overrides": [
    {
      "includes": [
        "app/workers/database.worker.ts",
        "app/lib/db-native.ts",
        "app/lib/db-shared.ts",
        "app/composables/useNotifications.ts",
        "app/composables/useTabReorder.ts"
      ],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "complexity": { "noExcessiveCognitiveComplexity": "off" },
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    }
  ]
}
