{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && pnpm typecheck 2>&1 | tail -20",
            "timeout": 30,
            "statusMessage": "Typechecking..."
          }
        ]
      }
    ]
  }
}
