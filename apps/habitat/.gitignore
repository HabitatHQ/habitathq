# Build output
.nuxt/
.output/
.data/
.cache/
coverage/
playwright-report/
test-results/
dist

# Node and pnpm
node_modules/
.pnpm-debug.log*

# Capacitor — native project dirs (android/, ios/) are tracked because they
# contain customisations (app icons, splash screens, build configs) that
# would be lost if regenerated with `cap add`.

# Env
.env
.env.*
!.env.example

# TypeScript
*.tsbuildinfo

# Generated at build time
public/licenses.json

### OS Files ###
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
*.lnk

### Editor and IDE Files ###
.idea
*.iws
*.sublime-workspace
*.swp
*.tmp
.vscode/
.vs/
.aider*

# Claude Code — track shared project hooks, ignore local settings
!.claude/
.claude/*
!.claude/settings.json

### Others ###

# local only files
scratch/

# Git worktrees (contain their own node_modules — must not be watched by Vite)
.worktrees/

# Runtime data
pids
*.pid
*.seed
*.pid.lock
*.log
