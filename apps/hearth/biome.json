{
  "root": false,
  "extends": ["../../biome.json"],

  "files": {
    "includes": ["app/**/*.ts", "app/**/*.vue", "nuxt.config.ts"]
  },

  "overrides": [
    {
      "includes": ["app/workers/database.worker.ts", "app/lib/db-native.ts"],
      "linter": {
        "rules": {
          "style": { "noNonNullAssertion": "off" },
          "complexity": { "noExcessiveCognitiveComplexity": "off" },
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    }
  ]
}
