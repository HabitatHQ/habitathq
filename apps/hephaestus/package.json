{
  "name": "hephaestus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "dev:pwa": "BUILD_TARGET=pwa nuxt dev",
    "build:pwa": "BUILD_TARGET=pwa nuxt generate",
    "build:native": "BUILD_TARGET=native nuxt generate && cap sync",
    "preview:pwa": "BUILD_TARGET=pwa nuxt generate && pnpm dlx serve .output/public",
    "clean": "rm -rf .output .nuxt",
    "postinstall": "nuxt prepare",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:open:android": "cap open android",
    "cap:open:ios": "cap open ios",
    "cap:run:android": "cap run android",
    "cap:run:ios": "cap run ios",
    "cap:sync": "cap sync",
    "cap:copy": "cap copy",
    "typecheck": "tsgo --noEmit",
    "typecheck:vue": "nuxt typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test": "vitest run && playwright test",
    "ci": "pnpm check && pnpm typecheck && pnpm test:unit"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.0",
    "@nuxt/ui": "^4.4.0",
    "@palladium/core": "workspace:*",
    "@palladium/nuxt": "workspace:*",
    "@palladium/sqlite-capacitor": "workspace:*",
    "@sqlite.org/sqlite-wasm": "3.51.2-build6",
    "fflate": "^0.8.2",
    "nuxt": "~4.3.1",
    "vue": "latest",
    "vue-router": "latest"
  },
  "devDependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@iconify-json/ph": "^1.2.2",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.7.0",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.0",
    "vitest": "^4.0.18",
    "workbox-precaching": "^7.4.0"
  }
}
